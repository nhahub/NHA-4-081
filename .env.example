# ==================== CREDENTIALS ====================
# Steam API
STEAM_API_KEY=your_steam_api_key_here

# PostgreSQL (Gold Layer - matches docker-compose postgres_general)
DB_URL=jdbc:postgresql://postgres_general:5432/sessiondb
DB_USER=your_db_user_here
DB_PASS=your_db_password_here

# pgAdmin Default Credentials
PGADMIN_EMAIL=your_pgadmin_email_here
PGADMIN_PASS=your_pgadmin_pass_here

# ==================== AIRFLOW SECRETS ====================
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASS=airflow

# ==================== PIPELINE CONFIG ====================
# How many games to fetch per run
BATCH_SIZE=1500
# How many hours before a game is considered stale and needs refreshing
STALE_HOURS=24
